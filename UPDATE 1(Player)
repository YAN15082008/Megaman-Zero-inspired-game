

extends CharacterBody2D


const SPEED = 595.0
const JUMP_VELOCITY = -600.0
var ACCEL = 600
var jump_count = 0
var COYOTE_TIME = 1
var coyote = 0
var attack = false
@onready var animation_player: AnimationPlayer = $AnimationPlayer
@onready var dashtimer: Timer = $Dashtimer
@onready var sprite: AnimatedSprite2D = $AnimatedSprite2D
var was_on_floor := true
@onready var original_scale = sprite.scale
const DUST_SCENE = preload("res://CENAS/fumaça/dust.tscn")
@onready var collision_shape_2d: CollisionShape2D = $CollisionShape2D
@export var max_hp := 100
var hp = max_hp
var knockback := Vector2.ZERO


	
func _physics_process(delta: float) -> void:
	
	velocity += knockback
	knockback = knockback.move_toward(Vector2.ZERO, 900.0 * delta)
	move_and_slide()
	
	
		
	# Makes you fall
	if not is_on_floor():
		velocity += get_gravity() * delta
	else: #Makes you jump on the ground on the floor
		jump_count = 0
	
	#Coyote time, obviously
	if is_on_floor():
		coyote = COYOTE_TIME
	else:
		coyote -=delta
		velocity += get_gravity() * delta
	if jump_count and coyote > 0:
		coyote = 0
		velocity.y = JUMP_VELOCITY
	
	# Handles double jump.
	if Input.is_action_just_pressed("jump") and jump_count < 2:
		jump_count += 1
		velocity.y = JUMP_VELOCITY
		
	if not was_on_floor and is_on_floor():
		_on_land()
	was_on_floor = is_on_floor()
		
	

	#Checks the input of the player to run
	var direction := Input.get_axis("move_left", "move_right") 
	#Handles the run and idle animations and physics.
	if direction and attack == false:
		$AnimatedSprite2D.play("run")
		velocity.x = move_toward(velocity.x, direction * SPEED,ACCEL * delta)
	elif attack == false:
		$AnimatedSprite2D.play("idle")
		velocity.x = move_toward(velocity.x, direction * -10,ACCEL * delta)
	
		
	#Handles the attack 
	if Input.is_action_just_pressed("Attack"):
			#Checks the attack to true
		attack = true
		#Checks if it is on floor and no attack movement when still
		if attack == true:
			#Checks for the animations
			$AnimationPlayer.play("attack")
			
		
		
	
	
		
	 	
	
	
		#Handles Dash
	var dash := Input.is_action_just_pressed("Dash")
	if dash:
		#Starts Dashtimer
		$Dashtimer.start(0)
		#Multiplys the max speed
		ACCEL *= 1.5
		#Velocity.x is now direction multiplied by the max speed
		velocity.x = direction * ACCEL
	#Makes you stop in the walls instead of gliding alongside it
	move_and_slide()
		
	#Dash timer for the player not to speed up to infinity
func _on_dashtimer_timeout() -> void:
		ACCEL = 600 * 1
	
#Squish and stretch the player and adds a little dust on his feet when he lands
func _on_land():
	var dust = DUST_SCENE.instantiate()
	get_parent().add_child(dust)

	dust.global_position = global_position + Vector2(0, 30)
	

	sprite.scale = original_scale * Vector2(1.3, 0.7)

	var t = create_tween()
	t.tween_property(sprite, "scale",original_scale, 0.3)\
		.set_trans(Tween.TRANS_ELASTIC)
	
	
	

	
	
	
	
	
	
	

			

	

	

#Checks that attack comes back to false when animation ends
func _on_animation_player_animation_finished(anim_name: StringName) -> void:
	if anim_name == "attack":
		attack = false

#Knockback when hit
func _on_hurtbox_area_entered(area: Area2D) -> void:
	if area.is_in_group("inimigos"):
		hp -= 10
		print("HP: ",hp)
		knockback = (global_position - area.global_position).normalized() * 150.0
		flash_white()
	if hp <= 0:
		die()
func die() -> void:
	queue_free()

#flashes white when hit
func flash_white() -> void:
	var tween := create_tween()
	sprite.modulate = Color.WHITE * 3.0
	tween.tween_interval(0.12)
	tween.tween_property(sprite, "modulate", Color.WHITE, 0.12)
	

	
		
		
#Added knockback and white flashes and life system
