extends Area2D

#Variable of death
var dead = false

#Checks the enemies sprites, body and colission
@onready var animated_sprite_2d: AnimatedSprite2D = $AnimatedSprite2D
@onready var enemy_body: CharacterBody2D = get_parent()
@onready var hitbox: CollisionShape2D = $"../Area2D/Hitbox"
	


#Checks to see if the enemy is alive and to play an animation if it does
func _process(delta):
	if dead == false:
		animated_sprite_2d.play("enemy")
#Checks to kill the enemy if interacted with group "scythe")
func _on_area_entered(area: Area2D) -> void:
	# 1.If it was hit by the player's scythe
#Makes the enemy explode on death
	if area.is_in_group("scythe"):
		dead = true
		animated_sprite_2d.play("explosao")
		
		
#Turns off the colission
func _on_animated_sprite_2d_animation_finished() -> void:
	if animated_sprite_2d.animation == "explosao":
		$"../Area2D/Hitbox".disabled = true
		queue_free()
